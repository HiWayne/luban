{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "api/*": ["src/api/*"],
      "@core/components/*": ["src/components/*"],
      "@core/baseComponents/*": ["src/render/baseComponents/*"],
      "@core/customComponents/*": ["src/render/customComponents/*"],
      "@core/types/*": ["src/types/*"],
      "router/*": ["src/router/*"],
      "assets/*": ["src/assets/*"],
      "@core/images/*": ["src/assets/images/*"],
      "@core/utils/*": ["src/shared/utils/*"],
      "@core/hooks/*": ["src/shared/hooks/*"],
      "@core/styles/*": ["src/shared/styles/*"]
    }
  }
}
