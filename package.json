{
  "name": "luban",
  "version": "0.1.0",
  "private": true,
  "dependencies": {},
  "scripts": {
    "dev": "cd ./packages/creation && npm run start",
    "dev:core": "cd ./packages/core && npm run start",
    "dev:creation": "cd ./packages/creation && npm run start",
    "build": "cd ./packages/core && npm run build && cd ../creation && npm run build",
    "build:core": "cd ./packages/core && npm run build",
    "build:creation": "cd ./packages/creation && npm run build",
    "_lint-staged": "lint-staged"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@ant-design/icons": "^4.7.0",
    "autoprefixer": "^9.8.8",
    "eslint": "^7.11.0",
    "eslint-config-react-app": "^7.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^7.0.4",
    "lerna": "^3.22.1",
    "lint-staged": "^11.2.6",
    "postcss": "^7.0.39",
    "prettier": "^2.4.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat@^2.2.17",
    "typescript": "^4.5.4",
    "validate-commit-msg": "^2.14.0"
  },
  "lint-staged": {
    "*.{js, jsx, css, less, sass, scss, styl, json}": [
      "prettier --write",
      "eslint"
    ],
    "*.{ts, tsx}?": [
      "prettier --parser=typescript --write",
      "eslint"
    ]
  }
}
