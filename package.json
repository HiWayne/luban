{
  "name": "luban",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "ramda": "^0.27.1",
    "immer": "^9.0.7",
    "antd": "^4.17.4",
    "axios": "^0.24.0",
    "dayjs": "^1.10.7",
    "emotion": "^11.0.0",
    "@emotion/core": "^11.0.0",
    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "react-router": "^5.2.1",
    "react-router-dom": "^5.3.0",
    "react-scripts": "4.0.3"
  },
  "scripts": {
    "dev": "cd ./packages/creation && npm run start",
    "dev:core": "cd ./packages/core && npm run start",
    "dev:creation": "cd ./packages/creation && npm run start",
    "build": "cd ./packages/core && npm run build && cd ../creation && npm run build",
    "build:core": "cd ./packages/core && npm run build",
    "build:creation": "cd ./packages/creation && npm run build",
    "_lint-staged": "lint-staged",
    "commit": "git-cz",
    "bootstrap": "lerna bootstrap"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@ant-design/icons": "^4.7.0",
    "autoprefixer": "^9.8.8",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^7.11.0",
    "eslint-config-react-app": "^7.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^7.0.4",
    "lerna": "^3.22.1",
    "lint-staged": "^11.2.6",
    "postcss": "^7.0.39",
    "prettier": "^2.4.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat@^2.2.17",
    "typescript": "^4.5.4",
    "@types/mockjs": "^1.0.4",
    "@types/ramda": "^0.27.46",
    "@types/react": "^17.0.33",
    "@types/react-dom": "^17.0.10",
    "@types/react-router": "^5.1.17",
    "@types/react-router-dom": "^5.3.2",
    "customize-cra": "^1.0.0",
    "mockjs": "^1.1.0",
    "react-app-rewired": "^2.1.8"
  },
  "lint-staged": {
    "*.{js, jsx, css, less, sass, scss, styl, json}": [
      "prettier --write",
      "eslint"
    ],
    "*.{ts, tsx}?": [
      "prettier --parser=typescript --write",
      "eslint"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  }
}
